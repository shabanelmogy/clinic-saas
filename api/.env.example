NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Connection pool (optional — defaults shown)
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=2000
# DB_SSL=false   # set to true for managed databases (RDS, Supabase, Neon)

# CORS
CORS_ORIGIN=http://localhost:3001

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string_minimum_32_chars_required
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth Rate Limiting (stricter — brute force protection)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Public API URL (used in Swagger docs — leave empty for local dev)
# API_URL=https://api.clinicsaas.com
